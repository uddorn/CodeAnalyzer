<Window x:Class="CodeAnalyzer.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Code Analyzer"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,12"
                BorderBrush="#E0E0E0" 
                BorderThickness="1">

            <StackPanel Orientation="Horizontal">

                <Button Content="В C#"
                        Click="BtnConvertToCSharp_Click"
                        Width="90"
                        Margin="0,0,8,0"/>

                <Button Content="У VB"
                        Click="BtnConvertToVB_Click"
                        Width="90"
                        Margin="0,0,8,0"/>

                <Button Content="Запустити демонстрацію"
                        Click="BtnRunArrayTest_Click"
                        Width="160"
                        FontWeight="Medium"/>

            </StackPanel>
        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    CornerRadius="8"
                    Padding="10"
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ВХІДНИЙ КОД"
                               Foreground="#005A9E"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="InputCodeBox"
                             Grid.Row="1"
                             Background="#FAFAFA"
                             Foreground="#333333"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"
                             Padding="5"
                             FontFamily="Consolas"
                             FontSize="14"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    CornerRadius="8"
                    Padding="10"
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="РЕЗУЛЬТАТ"
                               Foreground="#107C10"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="OutputBox"
                             Grid.Row="1"
                             Background="#FAFAFA"
                             Foreground="#333333"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"
                             Padding="5"
                             FontFamily="Consolas"
                             FontSize="14"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

        </Grid>

    </Grid>
</Window>